# Copy this file to .env and fill in real values.
# cp .env.example .env

# ----- LLM (Alibaba DashScope / OpenAI Compatible) -----
API_PROVIDER=OpenAI Compatible
BASE_URL=https://coding.dashscope.aliyuncs.com/v1
OPENAI_COMPATIBLE_API_KEY=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MODEL_ID=qwen3-coder-next

# Optional legacy-compatible keys (leave empty unless needed)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# ----- Database (SQLite default) -----
DB_BACKEND=sqlite
DB_PATH=./db/demo.db
INIT_SQL_PATH=./db/init.sql
AUDIT_DB_PATH=./db/audit.db

# ----- MySQL (optional when DB_BACKEND=mysql) -----
# MYSQL_DSN=mysql+pymysql://root:password@127.0.0.1:3306/test_db
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=test_db
